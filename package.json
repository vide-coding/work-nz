{
  "name": "pm-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "i": "pnpm install & cd src-tauri & cargo build",
    "kanban": "cross-env PORT=3000 HOST=0.0.0.0 npx vibe-kanban@latest",
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "autoprefixer": "^10.4.27",
    "lucide-vue-next": "^0.577.0",
    "marked": "^17.0.4",
    "postcss": "^8.5.8",
    "shiki": "^4.0.1",
    "tailwindcss": "^4.2.1",
    "vue": "^3.5.13",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.3",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "cross-env": "^10.1.0",
    "happy-dom": "^20.8.4",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.7",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.5"
  },
  "packageManager": "pnpm@9.15.2"
}
